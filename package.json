{
  "name": "opensec",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/api",
      "packages/auth",
      "packages/config",
      "packages/db",
      "packages/env",
      "packages/ui"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.9",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "bun run --cwd apps/web dev",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:migrate:prod": "bun run --cwd packages/db db:migrate:prod",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@opensec/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@opensec/config": "workspace:*",
    "@types/node": "^22.13.14",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
